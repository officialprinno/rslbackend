# Copy to .env for local development:  cp .env.example .env
# Never commit .env — it is listed in .gitignore.

DJANGO_SETTINGS_MODULE=config.settings.development

SECRET_KEY=change-me-to-a-long-random-secret
DEBUG=True

# Comma-separated hosts (no spaces)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Neon PostgreSQL connection string (required — local and production)
# Example: postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Angular / frontend origin(s)
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
CSRF_TRUSTED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# Optional: Jazzmin admin "Frontend" link
FRONTEND_URL=http://localhost:4200

# ── Railway production (set in Railway dashboard, not in .env) ─────────────
# DJANGO_SETTINGS_MODULE=config.settings.production
# SECRET_KEY=<strong-random-secret>
# DEBUG=False
# DATABASE_URL=<NEON_DATABASE_URL>
# DJANGO_ALLOWED_HOSTS=.up.railway.app
# CSRF_TRUSTED_ORIGINS=https://<your-service>.up.railway.app
# CORS_ALLOWED_ORIGINS=https://<your-frontend-domain>
# FRONTEND_URL=https://<your-frontend-domain>
