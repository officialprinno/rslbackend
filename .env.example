# Copy to .env for local development. On Railway, set variables in the dashboard.

SECRET_KEY=change-me-to-a-long-random-secret
DEBUG=True

DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Local PostgreSQL (used when DATABASE_URL is not set)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=rsl_db
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Railway: add a PostgreSQL plugin — DATABASE_URL is injected automatically.
# DATABASE_URL=postgres://user:password@host:5432/dbname

CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# ── Railway production (set in Railway dashboard) ─────────────
# DJANGO_SETTINGS_MODULE=config.settings.production
# SECRET_KEY=<strong-random-secret>
# DEBUG=False
# DJANGO_ALLOWED_HOSTS=rslbackend-production.up.railway.app
# CSRF_TRUSTED_ORIGINS=https://rslbackend-production.up.railway.app,https://your-frontend.com
# CORS_ALLOWED_ORIGINS=https://your-frontend.com
